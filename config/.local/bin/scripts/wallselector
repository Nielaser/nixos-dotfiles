#!/usr/bin/env bash

#for fish shell
swww img "$(find -L ~/Pictures/Wallpapers -type f | fzf --preview ' kitty +icat --transfer-mode=file --stdin=no --clear; kitty +icat --transfer-mode=file --stdin=no --place={$FZF_PREVIEW_COLUMNS}x{$FZF_PREVIEW_LINES}@0x0 {}' --preview-window 'up:50%:wrap')"

