layout {
    border {
        active-color   "#ffb3b4"
        inactive-color "#9f8c8c"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#ffb3b4"
        inactive-color "#9f8c8c"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#ffb3b480"
    }
}

